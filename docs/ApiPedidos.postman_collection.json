          "name": "Obtener envío por pedido",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/envios/pedido/{{pedidoId}}"
          }
        },
        {
          "name": "Obtener envío por tracking",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/envios/tracking/TRK-123456"
          }
        },
        {
          "name": "Listar envíos",
