    {
      "name": "Pagos",
      "item": [
        {
          "name": "Obtener pago por pedido",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pagos/pedido/{{pedidoId}}"
          }
        },
        {
          "name": "Listar pagos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pagos"
          }
        },
        {
          "name": "Obtener pago por id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pagos/{{pagoId}}"
          }
        }
        ,
        {
          "name": "Admin: actualizar estado pago (manual)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/pagos/{{pagoId}}/estado?estado=COMPLETADO"
          }
        }
      ]
    },
    {
      "name": "Flujo Pago Claro (IDs=7)",
      "item": [
        {
          "name": "1) Crear pedido (tienda 2, productos 4 y 5)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": {{clienteId}},\n  \"tiendaId\": 2,\n  \"detalles\": [\n    {\n      \"productoId\": 4,\n      \"cantidad\": 2\n    },\n    {\n      \"productoId\": 5,\n      \"cantidad\": 1\n    }\n  ],\n  \"direccionEntrega\": \"Calle 7 # 7-07\",\n  \"emailConfirmacion\": \"cliente7@mail.com\",\n  \"tipoEnvio\": \"EXPRESS\"\n}"
            },
            "url": "{{baseUrl}}/api/pedidos/crear"
          }
        },
        {
          "name": "2) Registrar pago (cambia pedido a PAGADO)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metodoPago\": \"TARJETA\",\n  \"monto\": 25000\n}"
            },
            "url": "{{baseUrl}}/api/pedidos/{{pedidoId}}/pago"
          }
        },
        {
          "name": "3) Verificar pedido en estado PAGADO",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pedidos/{{pedidoId}}"
          }
        },
        {
          "name": "4) Consultar pago por pedido",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/pagos/pedido/{{pedidoId}}"
          }
        },
        {
          "name": "5) Consultar transacción por pedido",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/transacciones/pedido/{{pedidoId}}"
          }
        }
      ]
    },
    {
      "name": "Transacciones",
      "item": [
        {
          "name": "Obtener transacción por pedido",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/transacciones/pedido/{{pedidoId}}"
          }
        },
