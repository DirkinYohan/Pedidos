            "method": "GET",
            "url": "{{baseUrl}}/api/envios"
          }
        },
        {
          "name": "Obtener envío por id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/envios/{{envioId}}"
          }
        }
      ]
